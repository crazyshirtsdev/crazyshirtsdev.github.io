  .grid { display: flex; flex-wrap: wrap; gap: 10px; padding: 18px; justify-content: flex-start; }
  .sticker {
    width: 1.5in; height: 1.5in; background: #fff; border: none; border-radius: 0;
    padding: 0.07in; display: flex; flex-direction: column; align-items: center; overflow: hidden;
  }
  .top { width: 100%; display: flex; justify-content: space-between; align-items: baseline; }
  .top .id { font-size: 11px; }
  .top .size { font-size: 11px; }
  .bc { width: 100%; height: 0.60in; object-fit: fill; margin: 3px 0; }
  .name { font-size: 8px; text-align: center; line-height: 1.1; flex: 1;
           display: flex; align-items: center; justify-content: center;
           overflow: hidden; word-break: break-word; }
  .price { font-size: 13px; padding-bottom: 2px; }
  .hidden { display: none !important; }
  @media print {
    body { background: #fff; }
    .bar { display: none; }
    .grid { gap: 0; padding: 0; }
    .sticker { border-radius: 0; page-break-inside: avoid; }
  }
</style>
